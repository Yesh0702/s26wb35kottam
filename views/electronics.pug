extends layout

block content
  h1= title

  //- Part 6, Step 1: Unbuffered server-side code (the array)
  -
    let results = [
      { item_name: "Smartphone", brand: "Apple", price: 999 },
      { item_name: "Laptop", brand: "Dell", price: 1200 },
      { item_name: "Headphones", brand: "Sony", price: 350 }
    ]

  //- Part 6, Steps 2, 3, & 4: Outermost container and row
  div(class="container-fluid")
    div(class="row")
      //- BONUS: Iterate over results getting both value (item) and index
      each item, index in results
        //- BONUS: Add onclick property that calls buy(index)
        div(class="col-sm-2", onclick=`buy(${index})`)
          h3 #{item.item_name}
          p Brand: #{item.brand}
          p Price: $#{item.price}

  //- BONUS: Script block for the buy function
  script.
    function buy(index) {
      alert(`You purchased item ${index + 1}.`);
    }